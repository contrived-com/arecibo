{
  "uid": "arecibo-container-observability",
  "title": "Arecibo - Container Observability",
  "tags": ["arecibo", "containers"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "serviceName",
        "type": "textbox",
        "label": "Service Name",
        "current": { "value": "" },
        "options": []
      },
      {
        "name": "environment",
        "type": "textbox",
        "label": "Environment",
        "current": { "value": "" },
        "options": []
      },
      {
        "name": "instanceId",
        "type": "textbox",
        "label": "Instance ID",
        "current": { "value": "" },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Network RX by Container (30s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "arecibo-api", "type": "yesoreyeram-infinity-datasource" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "/query/container-metrics",
          "url_options": {
            "method": "GET",
            "params": [
              { "key": "start", "value": "${__from:date:iso}" },
              { "key": "end", "value": "${__to:date:iso}" },
              { "key": "serviceName", "value": "${serviceName}" },
              { "key": "environment", "value": "${environment}" },
              { "key": "instanceId", "value": "${instanceId}" },
              { "key": "rollup", "value": "container" },
              { "key": "bucketWidthSec", "value": "30" },
              { "key": "maxRows", "value": "10000" }
            ]
          },
          "root_selector": "data",
          "columns": [
            { "selector": "bucket", "text": "Time", "type": "timestamp" },
            { "selector": "networkRxBytes", "text": "Network RX Bytes", "type": "number" },
            { "selector": "instanceId", "text": "Instance", "type": "string" }
          ]
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "min", "max", "mean"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
