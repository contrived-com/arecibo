{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arecibo/schemas/query/heartbeat-freshness/1.0.0",
  "type": "object",
  "required": ["data", "meta"],
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["serviceName", "environment", "instanceId", "lastHeartbeatAt", "staleSec", "status"],
        "properties": {
          "serviceName": {
            "type": "string",
            "minLength": 1
          },
          "environment": {
            "type": "string"
          },
          "instanceId": {
            "type": "string",
            "minLength": 1
          },
          "lastHeartbeatAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "Z$"
          },
          "staleSec": {
            "type": "number",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "enum": ["fresh", "stale", "offline"]
          },
          "goDark": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "meta": {
      "type": "object",
      "required": ["totalRows", "start", "end"],
      "properties": {
        "totalRows": {
          "type": "integer",
          "minimum": 0
        },
        "start": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "end": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "cursor": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
